FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build
RUN if [ -d dist ]; then cp -R dist /tmp/webroot; \
    elif [ -d build ]; then cp -R build /tmp/webroot; \
    else echo "React build output directory not found (expected dist/ or build/)" && exit 1; fi

FROM nginx:1.27-alpine
COPY --from=builder /tmp/webroot/ /usr/share/nginx/html/
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
